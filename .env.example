# Copy this file to .env.local for local-only home-globe imagery validation.
# Keep .env.local untracked. Do not commit your Google API key.

# Default baseline: keep the approved offline Earth imagery.
VITE_HOME_GLOBE_IMAGERY_MODE=offline

# Switch to the Google Map Tiles enhanced home-globe path when you have a local key.
# VITE_HOME_GLOBE_IMAGERY_MODE=google-satellite
# VITE_GOOGLE_MAP_TILES_API_KEY=replace-with-your-google-map-tiles-api-key

# Optional session settings for the Google satellite composite.
# VITE_GOOGLE_MAP_TILES_LANGUAGE=en-US
# VITE_GOOGLE_MAP_TILES_REGION=US
# VITE_GOOGLE_MAP_TILES_ZOOM=3
